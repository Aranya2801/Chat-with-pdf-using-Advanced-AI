# ═══════════════════════════════════════════════════════════════════
# Chat-with-PDF Advanced AI — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit your .env file to version control!
# ═══════════════════════════════════════════════════════════════════

# ── Required: OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Optional: Vector Store Backend ────────────────────────────────
# Options: faiss (default, local), chroma (persistent local), pinecone (cloud)
VECTOR_BACKEND=faiss

# ── Optional: Pinecone (cloud vector store) ───────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=chatpdf-index

# ── Optional: Persistence ─────────────────────────────────────────
# Local directory to persist vector index between sessions
PERSIST_DIR=./data/vectorstore

# ── Optional: Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Optional: App Settings ────────────────────────────────────────
DEFAULT_MODEL=gpt-4o
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
DEFAULT_TOP_K=8
DEFAULT_CHUNK_SIZE=1000
DEFAULT_CHUNK_OVERLAP=200
DEFAULT_TEMPERATURE=0.1

# ── Optional: Streamlit ───────────────────────────────────────────
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_HEADLESS=true
